<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#CC0D0D0D"
    app:cardCornerRadius="28dp"
    app:cardElevation="12dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="#33FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="28dp">

        <TextView
            android:id="@+id/textHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/ndot_57"
            android:text="@string/tile_light_label"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/ndot_57"
            android:text="100%"
            android:textColor="@android:color/white"
            android:textSize="44sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textHeader" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderTile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="1"
            app:labelBehavior="gone"
            app:thumbColor="@android:color/white"
            app:thumbRadius="12dp"
            app:thumbStrokeColor="#20FFFFFF"
            app:thumbStrokeWidth="4dp"
            app:trackColorActive="@android:color/white"
            app:trackColorInactive="#33FFFFFF"
            app:trackHeight="12dp"
            app:haloColor="#1AFFFFFF"
            app:layout_constraintTop_toBottomOf="@id/textValue" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggleTorch"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="24dp"
            android:text="Toggle Light"
            android:textColor="@android:color/white"
            android:fontFamily="@font/ndot_57"
            android:letterSpacing="0.1"
            app:backgroundTint="#26FFFFFF"
            app:cornerRadius="20dp"
            app:layout_constraintTop_toBottomOf="@id/sliderTile"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
